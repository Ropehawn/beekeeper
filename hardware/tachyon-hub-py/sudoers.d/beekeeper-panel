# Allow the panel daemon (running as `particle`) to issue the one-shot
# `systemctl restart beekeeper-hub-py` command that the M1 button's
# long-press triggers. Scoped narrowly — particle cannot use sudo for
# anything else via this entry.
#
# Install:
#   sudo cp hardware/tachyon-hub-py/sudoers.d/beekeeper-panel /etc/sudoers.d/
#   sudo chmod 440 /etc/sudoers.d/beekeeper-panel
#   sudo visudo -c -f /etc/sudoers.d/beekeeper-panel    # syntax-check
#
# WARNING: do not edit this file in place; visudo lints first or you risk
# breaking sudo entirely. Edit in the repo, copy via `cp`.

particle ALL=(root) NOPASSWD: /bin/systemctl restart beekeeper-hub-py
